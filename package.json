{
  "name": "kronfort",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "tsc && next build",
    "start": "next start",
    "postbuild": "next-sitemap",
    "prettier": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\"",
    "lint": "tsc && eslint \"src/**/*.ts\" \"src/**/*.tsx\"",
    "lint:fix": "tsc && eslint \"src/**/*.ts\" \"src/**/*.tsx\" --fix",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "lint:scss:fix": "stylelint \"src/**/*.scss\" --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.6.1",
    "@next/env": "^15.2.1",
    "@next/third-parties": "^14.2.4",
    "@pbe/react-yandex-maps": "^1.2.5",
    "@phosphor-icons/react": "^2.1.7",
    "@types/react-transition-group": "^4.4.12",
    "antd": "^5.18.0",
    "clsx": "^2.1.0",
    "dompurify": "^3.1.5",
    "embla-carousel-class-names": "^8.5.2",
    "embla-carousel-react": "^8.5.2",
    "kronfort": "file:",
    "next": "^14.2.4",
    "normalize.css": "^8.0.1",
    "primereact": "^10.9.2",
    "react": "^18",
    "react-countup": "^6.5.3",
    "react-dom": "^18",
    "react-hook-form": "^7.52.0",
    "react-multi-carousel": "^2.8.5",
    "react-parallax-mouse": "^2.1.0",
    "react-transition-group": "^4.4.5",
    "reactjs-popup": "^2.0.6",
    "sharp": "^0.33.4",
    "swiper": "^11.1.4",
    "zustand": "^3.7.2"
  },
  "devDependencies": {
    "@svgr/webpack": "^8.1.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.1",
    "next-sitemap": "^4.2.3",
    "prettier": "3.2.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.2",
    "react-content-loader": "^6.0.3",
    "sass": "^1.70.0",
    "stylelint-config-css-modules": "^4.4.0",
    "stylelint-config-idiomatic-order": "^10.0.0",
    "stylelint-config-standard-scss": "^13.0.0",
    "stylelint-scss": "^6.1.0",
    "typescript": "^5"
  },
  "overrides": {
    "stylelint-order": "6.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c tsc --noEmit",
      "eslint --fix",
      "prettier -w"
    ],
    "*.scss": [
      "stylelint --fix",
      "prettier -w"
    ]
  },
  "resolutions": {
    "react": "18",
    "@types/react": "18"
  }
}
